<script>
/* video-play-pause : play/pause video based on element visibility */

jQuery.fn.isInViewport = function() {
    var elementTop = jQuery(this).offset().top;
    var elementBottom = elementTop + jQuery(this).outerHeight();
    var viewportTop = jQuery(window).scrollTop();
    var viewportBottom = viewportTop + jQuery(window).height();
	var elementHeight = elementBottom-elementTop;
    var viewportHeight = viewportBottom-viewportTop;
    var viewportCenter = viewportTop + (viewportHeight/2);

  	// play video on element on viewboard
	//	return elementBottom > viewportTop && elementTop < viewportBottom;

	// play video after element reached half screen
	viewportTop = viewportTop + ( elementHeight / 2 );
	viewportBottom = viewportBottom - ( elementHeight / 2 );
 	if( viewportTop > viewportCenter) { viewportTop = viewportCenter; }
 	if( viewportBottom < viewportCenter) { viewportBottom = viewportCenter; }
  	return elementBottom >= viewportTop && elementTop <= viewportBottom;

};

jQuery(window).on('resize scroll', function() {
	jQuery.each(jQuery('.video-play-pause video') , function( key, obj) {
		if( jQuery(obj).isInViewport() ) {	obj.play();	}
		else { obj.pause(); }
	});
});

</script>
