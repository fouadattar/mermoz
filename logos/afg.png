<script>
/* fix vimeo mp4 video loading issue : refresh 1 hrs old browser cache */
jQuery( document ).ready(function() {
	const olc_server_timestamp = 1772664982000;
	const olc_client_date= new Date();
	olc_client_timestamp = olc_client_date.getTime();
	var cache_limit = 1*60*60*1000;// 1 hrs
	console.log("olc_server_timestamp");
	console.log(olc_server_timestamp);
	console.log("olc_client_timestamp");
	console.log(olc_client_timestamp);
	console.log("cache_limit");
	console.log(cache_limit);
	if( (olc_client_timestamp-olc_server_timestamp) > cache_limit ) 
	{ 
		console.log("refresh required");
//		location.reload();	
	}
});
</script>

