        jQuery('.elementor-tab-content').removeClass('elementor-active');
        jQuery('.elementor-tab-content').hide();
        jQuery("#" + tab_id).addClass('current');
    });
});
*/
/* tab interactive add class on hover 
jQuery('.bdt-tabs-wrap .bdt-tabs-item').hover(function(){
  var thId = jQuery(this).attr('data-slide');
  jQuery('.bdt-content-wrap .swiper-slide').each(function(){
      if(jQuery(this).attr('data-swiper-slide-index') != undefined){
        jQuery(this).removeClass('current');
      }
  });
  jQuery('.swiper-slide[data-swiper-slide-index*='+thId+']').addClass('current');
});
*/


// Sticky class on scroll
// When the user scrolls the page, execute myFunction
window.onscroll = function() {OlcStickyHeader()};

// Get the headers
var header = document.querySelector(".elementor-location-header");
var progressBar = document.querySelector(".progess-tracker");

// Get the offset position of the navbar
var sticky = header.offsetTop;

// Add the sticky class to the header and subheader when you reach their scroll position. Remove "sticky" when you leave the scroll position
function OlcStickyHeader() {
	if (window.pageYOffset > sticky) {
		header.classList.add("active-sticky");
		progressBar.classList.add("active-sticky");
	} else {
		header.classList.remove("active-sticky");
		progressBar.classList.remove("active-sticky");
	}
}

/***** Scroll into view *****/
function isScrolledIntoView(elem) {

    if (!jQuery(elem).length) return false;

    var docViewTop = jQuery(window).scrollTop();
    var docViewBottom = docViewTop + jQuery(window).height();

    var elemTop = jQuery(elem).offset().top;
    var elemBottom = elemTop + jQuery(elem).height();

    return ((elemTop <= docViewBottom) && (elemBottom >= docViewTop));
}

jQuery(window).scroll(function () {
	jQuery('.transparent-header + #main > .page-content > div.elementor > section:first-child, .opacity-header + #main > .page-content > div.elementor > section:first-child').each(function () {
        if (isScrolledIntoView(this)) {
        jQuery('#main-header').removeClass('color-header');
        jQuery('.progress-bar-section').hide();
        }
        else {
        jQuery('#main-header').addClass('color-header');
        jQuery('.progress-bar-section').show();
		}
	});
});
jQuery(document).ready(function () {
  jQuery('.transparent-header .progress-bar-section').hide();
});


/* scroll to top button */
jQuery(document).ready(function () {
var scrollToTopBtn = document.querySelector(".scrollToTopBtn");
var rootElement = document.documentElement;

function handleScroll() {
  // Do something on scroll
  var scrollTotal = rootElement.scrollHeight - rootElement.clientHeight;
//    if (jQuery(window).width() > 990){
//        if (rootElement.scrollTop / scrollTotal > 0.8) {
//        // Show button
//        scrollToTopBtn.classList.add("showBtn");
//        } else {
//        // Hide button
//        scrollToTopBtn.classList.remove("showBtn");
//        }
//    }
//    else {
        if (rootElement.scrollTop / scrollTotal > 0.1) {
        // Show button
        scrollToTopBtn.classList.add("showBtn");
        } else {
        // Hide button
        scrollToTopBtn.classList.remove("showBtn");
        }
//    }
}

function scrollToTop() {
  // Scroll to top logic
  rootElement.scrollTo({
    top: 0,
    behavior: "smooth"
  });
}
scrollToTopBtn.addEventListener("click", scrollToTop);
document.addEventListener("scroll", handleScroll);
});




/* link to next section */
jQuery(document).ready(function($) {
    $(".next-section a").click(function() {
		var cls = $(this).parents('section').next('section').offset().top - 72;
		$("html, body").animate({scrollTop: cls}, "slow");
	});
});

/* Use Attribute to change the color of the border left animation
jQuery( '.left-border-animation' ).each(function() {
	var newColor = jQuery(this).data("bgcolor");
  TweenMax.to(".border-left", 0.5, {backgroundColor:newColor});
});
*/


/* Add a div "border-left" to the left of ".left-border-animation" */
jQuery( '.left-border-animation' ).each(function() {
jQuery(this).find('.elementor-widget-wrap').before('<div class="add-border border-left"></div>');
});
/* Add a div "border-left" to the left of ".left-border-animation" */
jQuery( '.right-border-animation' ).each(function() {
jQuery(this).find('.elementor-widget-wrap').after('<div class="add-border border-right"></div>');
});

/* add inview class to svg. set olc-inview class name to svg element for add this effect */
jQuery(document).ready(function() {
    var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
            if (entry.isIntersecting) {
                jQuery(entry.target).addClass('inview');
            }
        });
    }, { threshold: 0.8 }); // 80% visibility

    jQuery('.left-border-animation, .right-border-animation').each(function() {
        observer.observe(this);
    });
});


/* Add a class if vimeo url */
jQuery('.bdt-custom-gallery').ready(function($) {
    $('.bdt-gallery-item a[href*="vimeo"]').each(function() {
        jQuery(this).addClass('video-vimeo');
    });
});

/* jQuery make entire div clickable */
jQuery(function ($) { // wait while jQuery loads (document-ready)
    $('.link-entire-block').click(function () { // open the link if user clicked anywhere on block 
        var link_url = $(this).find('a').attr('href');
        var target_attr = $(this).find('a').attr('target');
        if (target_attr == '_blank') {
            window.open(link_url);
        } else {
            window.location.href = link_url;
        }
    });
});

/* in the news page Add class to the section "change-color" when hover on a .news-block*/
jQuery(document).ready(function()
  {
    jQuery('.block-news').hover(
      function(){ 
        jQuery('.change-color').addClass("active"); //Add an active class to the anchor
      },
      function() {
        jQuery('.change-color').removeClass("active"); //Remove an active class to the anchor
      }
   )
 });

jQuery(document).ready(function ($) {
  // Get the source link element
  var sourceLink = $("section.block-news a");

  if (sourceLink.length) {
    // Make the section.block-news clickable and redirect to the link's destination
    $("section.block-news").on("click", function () {
      var linkUrl = sourceLink.attr("href");
      var linkTarget = sourceLink.attr("target");
      if (linkTarget === "_blank") {
        window.open(linkUrl);
      } else {
        window.location.href = linkUrl;
      }
    });
  }
});



</script>
