/*html:not([lang="es"])  .trp-language-item[title="ES"]{ display:none; } */
/* html:not([lang="zh"])  .trp-language-item[title="ZH"]{ display:none; } */
/*html:not([lang="ar"])  .trp-language-item[title="AR"]{ display:none; } */
html:not([lang="fr"])  .trp-language-item[title="FR"]{ display:none; } 
/* html:not([lang="de"])  .trp-language-item[title="DE"]{ display:none; } */


.trp-shortcode-switcher__wrapper:not(:hover),
.trp-language-switcher:not(:hover){
    background: transparent !important;
    border: 0;
}
@media screen and (min-width: 768px) {
header.transparent-header:not(.active-sticky) .trp-language-switcher:not(:hover) .trp-language-item-name,
header.transparent-header:not(.active-sticky) .trp-language-switcher:not(:hover)  .trp-shortcode-arrow path {
    color: white;
    stroke: white;
}
}
.trp-language-item__current{
    padding-right: 5px;
}
.trp-language-switcher.trp-ls-dropdown.trp-open-on-hover:hover {
    min-width: 130px;
}

.trp-language-switcher.trp-shortcode-overlay :not(:hover) svg{
    display: none;
}


/* Arabic language adjustement */
html[lang="ar"] #main-header{
    direction: ltr;
}
html[lang="ar"] .add-border.border-left{
    left:  auto;
    right: -2px;
}
html[lang="ar"] .add-border.border-right{
    right:  auto;
    left: -2px;
}
html[lang="ar"] .ee-offcanvas__container > :not(header) .left-border-animation .elementor-widget-wrap {
    padding-left: 0 !important;
    padding-right: 40px !important;
}
html[lang="ar"] .ee-offcanvas__container > :not(header) .elementor-section > .elementor-container > .elementor-column:not(:last-child) > .elementor-widget-wrap{
    padding-left: 40px;
    padding-right: 0;
}

html[lang="ar"] .elementor-widget-container{
    text-align: right;
}
html[lang="ar"] .animated.fadeInLeft {
    animation-name: fadeInRight;
}
html[lang="ar"] .animated.fadeInRight {
    animation-name: fadeInLeft;
}


</style>
<!-- end Simple Custom CSS and JS -->
<!-- start Simple Custom CSS and JS -->
<style>
nav li.menu-item.js-hover::after {
    content: " ";
    width: 100px;
    position: absolute;
    height: 1000px;
    top: -500px;
    right: -50px;
}
nav li.menu-item:not(.js-hover) > ul.sub-menu { opacity:0 !important; }
nav li.menu-item.js-hover > ul.sub-menu,
nav li.menu-item:hover > ul.sub-menu{
	height: 100% !important;
	opacity: 1 !important;
	transform: scale(1) !important;
}
nav li.menu-item.js-hover > ul.sub-menu > li.menu-item,
nav li.menu-item:hover > ul.sub-menu > li.menu-item{ 
	opacity:1 !important; transition: opacity .5s ease-in-out 0s; 
}



/* MENU VERTICAL */

@media only screen and (min-width: 991px) {
.menu-vertical ul.elementor-nav-menu > li.menu-item:not(:first-child){padding-top:10%;}

.menu-vertical .sub-menu.elementor-nav-menu--dropdown > li.menu-item:not(:first-child) {padding-top:10% !important;}

.menu-vertical ul.elementor-nav-menu li.menu-item a span.sub-arrow{
	content: url("data:image/svg+xml,%3Csvg version='1.1' id='Layer_1' xmlns='http://www.w3.org/2000/svg' xmlns:xlink='http://www.w3.org/1999/xlink' x='0px' y='0px' viewBox='0 0 503.8 178' style='enable-background:new 0 0 503.8 178;' xml:space='preserve'%3E%3Cpath style='fill:%23ffffff;' d='M346.1,5c3.3,0,5.8,0.7,9,3.3l140,145.6c3.5,4.2,4.1,8.4,1.8,13.5c-2.1,4.6-9.8,5.5-15.4,5.5 L16.7,173c-5.6-0.1-11.2-5.7-11.2-11.3c0-5.6,5.6-11.2,11.2-11.1h444.1L339,23.9c-3-3-4-7.8-2.6-11.8C337.9,8.2,342.1,5,346.1,5 L346.1,5z'/%3E%3C/svg%3E%0A");
	background-repeat: no-repeat;
	width: 60px !important;
	padding: 0 0 0 20px !important;
	margin-bottom: -8px;
}
.menu-vertical ul.elementor-nav-menu li.menu-item a{
	display: flex;
	align-items: flex-end;
}

.menu-vertical ul.active > li:not(.active) > a{opacity:0.3;}
		
.menu-vertical ul.elementor-nav-menu:hover > li.menu-item:not(:hover) a,
.menu-vertical ul.elementor-nav-menu:hover ul.sub-menu:hover > li.menu-item:not(:hover) a {opacity: 0.3 !important;}

}
   

.menu-vertical ul.elementor-nav-menu{
    flex-direction: column;
}
.menu-vertical ul.elementor-nav-menu li.menu-item{
    position: unset;
    flex-grow: 0 !important;
    flex-basis: auto !important;
}
.menu-vertical  ul.sub-menu{
    display: block !important;
    background: transparent !important;
    box-shadow: none;
    left: 100% !important;
    height: 100%;
    position: absolute;
    transform: scale(0);
    width: auto;
	top: 0px !important;
    transform-origin: top;
}
.menu-vertical .elementor-nav-menu > li.menu-item > ul.sub-menu{top:0px !important;}
.menu-vertical .elementor-nav-menu > li.menu-item > ul.sub-menu > li.menu-item > ul.sub-menu{margin-top: 1px;  top:0px !important;}
.menu-vertical .elementor-nav-menu--layout-horizontal .elementor-nav-menu > li > ul, 
.menu-vertical .elementor-nav-menu--layout-horizontal .elementor-nav-menu > li > ul > li > ul { left: 100% !important; }

.menu-vertical ul.sub-menu li.menu-item{
        opacity:0;
        width: 100%;
        display: flex;
        flex-grow: 1;
        flex-basis: 100%;
        display: block;
    }
    .menu-vertical  ul.sub-menu.hoveractive,
    .menu-vertical  ul.sub-menu:hover{
        transform-origin: top;
        display: flex !important;
        flex-direction: column;
        height: 100%;
        width: auto;
        display: block !important;
        top: 0px !important;
        transform: scale(1);
    }

.menu-vertical .menu-item a sup{margin:-20px 7px 0 -3px;}

.menu-vertical li.menu-item.show-current-country:before,
.menu-vertical li.menu-item.afficher-pays-courant:before{
    text-transform: uppercase;
    padding: 0 0 5px 0;
    display:block;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
	font-weight: 600;
}




</style>
